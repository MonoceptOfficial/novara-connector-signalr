<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
    <PackageId>Novara.Connector.SignalR</PackageId>
    <Version>26.4.230</Version>
    <Authors>Monocept</Authors>
    <Company>Monocept</Company>
    <Description>SignalR Hub connector for Novara — real-time notification delivery + client lifecycle events from the internal NovaraSignalRHub service.</Description>
    <PackageTags>novara;connector;signalr;realtime;internal</PackageTags>
    <GenerateDocumentationFile>true</GenerateDocumentationFile>
  </PropertyGroup>
  <ItemGroup>
    <FrameworkReference Include="Microsoft.AspNetCore.App" />
  </ItemGroup>
  <ItemGroup>
    <PackageReference Include="Novara.Module.SDK"/>
  </ItemGroup>
</Project>
